# =============================================================================
# Hotel Yuvaan Frontend — environment templates
# =============================================================================
# Committed files:
#   .env.dev   → remote dev API + Vercel Preview builds  (npm run dev / build:dev)
#   .env.prod  → production API + Vercel Production       (npm run build:prod)
#
# Local backend (committed):
#   .env.localhost → localhost API                          (npm run dev:local)
# Personal overrides (gitignored via *.local):
#   .env.localhost.local → optional machine-specific tweaks
#
# Vercel auto-build (npm run build):
#   VERCEL_ENV=production → uses .env.prod
#   VERCEL_ENV=preview    → uses .env.dev
#
# Also set in Vercel Dashboard (for serverless /api/* routes at runtime):
#   Production: BACKEND_API_URL, API_VERSION_PATH
#   Preview:    BACKEND_API_URL, API_VERSION_PATH
# =============================================================================

# --- .env.dev (committed) ---
# VITE_APP_ENV=dev
# VITE_SITE_URL=https://dev.hotelyuvaan.com
# VITE_BACKEND_API_URL=https://dev-api.hotelyuvaan.com
# VITE_API_VERSION_PATH=/api/v1.0.0
# BACKEND_API_URL=https://dev-api.hotelyuvaan.com
# API_VERSION_PATH=/api/v1.0.0

# --- .env.prod (committed) ---
# VITE_APP_ENV=prod
# VITE_SITE_URL=https://hotelyuvaan.com
# VITE_BACKEND_API_URL=https://api.hotelyuvaan.com
# VITE_API_VERSION_PATH=/api/v1.0.0
# BACKEND_API_URL=https://api.hotelyuvaan.com
# API_VERSION_PATH=/api/v1.0.0

# --- .env.localhost (committed; npm run dev:local) ---
# VITE_APP_ENV=dev
# VITE_SITE_URL=http://localhost:5173
# VITE_BACKEND_API_URL=http://localhost:8080
# VITE_API_VERSION_PATH=/api/v1.0.0
# BACKEND_API_URL=http://localhost:8080
# API_VERSION_PATH=/api/v1.0.0
